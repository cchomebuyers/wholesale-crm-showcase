# Copy this file to ".env" and fill in your Gmail details to enable sending email.
# Use a Google "App Password" (NOT your normal password):
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an app password:       https://myaccount.google.com/apppasswords
#   3. Paste the 16-character code below (spaces are fine).

GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: a nicer "from" line, e.g. "Sonny | Acquisitions <you@gmail.com>"
# GMAIL_FROM=

# Optional: change the port the app runs on (default 4000)
# PORT=4000
